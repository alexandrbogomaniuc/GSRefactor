{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abs.example/contracts/ws-v1/abs-gs-v1-error.schema.json",
  "title": "ABS GS ERROR v1",
  "allOf": [
    {
      "$ref": "./abs-gs-v1-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "ERROR"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "code",
            "category",
            "message",
            "retryable"
          ],
          "properties": {
            "code": {
              "type": "string",
              "minLength": 1
            },
            "category": {
              "type": "string",
              "enum": [
                "validation",
                "state",
                "dependency",
                "auth",
                "rate_limit",
                "internal"
              ]
            },
            "message": {
              "type": "string",
              "minLength": 1
            },
            "retryable": {
              "type": "boolean"
            },
            "details": {
              "type": "object"
            }
          }
        }
      }
    }
  ]
}
