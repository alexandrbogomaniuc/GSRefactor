{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abs.example/contracts/ws-v1/abs-gs-v1-envelope.schema.json",
  "title": "ABS GS WebSocket Envelope v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "type",
    "traceId",
    "sessionId",
    "bankId",
    "gameId",
    "timestamp",
    "seq",
    "payload"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "type": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "traceId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "bankId": {
      "type": "string",
      "minLength": 1
    },
    "gameId": {
      "type": "string",
      "minLength": 1
    },
    "operationId": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "payload": {
      "type": "object"
    }
  }
}
