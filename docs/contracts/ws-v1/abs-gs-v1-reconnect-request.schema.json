{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abs.example/contracts/ws-v1/abs-gs-v1-reconnect-request.schema.json",
  "title": "ABS GS RECONNECT_REQUEST v1",
  "allOf": [
    {
      "$ref": "./abs-gs-v1-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "RECONNECT_REQUEST"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "lastAckSeq"
          ],
          "properties": {
            "lastAckSeq": {
              "type": "integer",
              "minimum": 0
            },
            "lastKnownOperationId": {
              "type": "string",
              "minLength": 1
            },
            "clientBuild": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  ]
}
