{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abs.example/contracts/ws-v1/abs-gs-v1-bet-request.schema.json",
  "title": "ABS GS BET_REQUEST v1",
  "allOf": [
    {
      "$ref": "./abs-gs-v1-envelope.schema.json"
    },
    {
      "type": "object",
      "required": [
        "operationId"
      ],
      "properties": {
        "type": {
          "const": "BET_REQUEST"
        },
        "operationId": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "roundId",
            "amount",
            "currency"
          ],
          "properties": {
            "roundId": {
              "type": "string",
              "minLength": 1
            },
            "amount": {
              "type": "string",
              "pattern": "^-?\\d+(\\.\\d{1,6})?$"
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "betLines": {
              "type": "integer",
              "minimum": 1
            },
            "metadata": {
              "type": "object"
            }
          }
        }
      }
    }
  ]
}
