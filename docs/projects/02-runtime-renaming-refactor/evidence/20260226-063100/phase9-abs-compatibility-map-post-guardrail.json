{
  "type": "phase9-abs-compatibility-map",
  "version": 1,
  "scope": "gs-server",
  "status": "draft-manual-review-first",
  "notes": [
    "No big-bang replacement. Use wave-based rollout with compatibility aliases.",
    "Context-sensitive tokens (for example mq) are review-only by default.",
    "Internal package/class renames require wrappers/delegation before removal.",
    "Brand token replacements are review-only after runtime safety audit (no automatic apply)."
  ],
  "waves": [
    {"id": "W0", "label": "docs-and-nonruntime-strings", "allowsAutomaticApply": false, "pathProfile": "w0_safe_targets"},
    {"id": "W1", "label": "config-aliases", "allowsAutomaticApply": true, "pathProfile": "w1_config_targets"},
    {"id": "W2", "label": "api-docs-and-contract-text", "allowsAutomaticApply": true, "pathProfile": "w2_contract_doc_targets"},
    {"id": "W3", "label": "code-wrappers-and-compat-delegation", "allowsAutomaticApply": false, "pathProfile": "w3_wrapper_candidates"},
    {"id": "W4", "label": "legacy-alias-removal-explicit-approval", "allowsAutomaticApply": false, "pathProfile": "full_scan"}
  ],
  "pathProfiles": {
    "full_scan": {
      "mode": "all"
    },
    "w0_safe_targets": {
      "mode": "extension_and_path_filters",
      "includeExtensions": ["md", "xml", "properties", "yml", "yaml", "jsp"],
      "excludePathContains": ["/src/main/java/", "/src/test/java/", "/target/"]
    },
    "w1_config_targets": {
      "mode": "extension_and_path_filters",
      "includeExtensions": ["xml", "properties", "yml", "yaml"],
      "excludePathContains": ["/src/main/java/", "/src/test/java/", "/target/"]
    },
    "w2_contract_doc_targets": {
      "mode": "extension_and_path_filters",
      "includeExtensions": ["md", "json", "yaml", "yml", "xml"],
      "excludePathContains": ["/src/main/java/", "/src/test/java/", "/target/"]
    },
    "w3_wrapper_candidates": {
      "mode": "extension_and_path_filters",
      "includeExtensions": ["java", "xml", "properties"],
      "excludePathContains": ["/target/"]
    }
  },
  "mappings": [
    {"legacy": "betsoft", "replacement": "abs", "replacementUpper": "ABS", "category": "brand", "defaultWave": "W0", "reviewOnly": true},
    {"legacy": "betsoft gaming", "replacement": "ABS", "replacementUpper": "ABS", "category": "brand", "defaultWave": "W0", "reviewOnly": true},
    {"legacy": "nucleus", "replacement": "abs", "replacementUpper": "ABS", "category": "brand", "defaultWave": "W0", "reviewOnly": true},
    {"legacy": "maxquest", "replacement": "abs", "replacementUpper": "ABS", "category": "brand", "defaultWave": "W0", "reviewOnly": true},
    {"legacy": "maxduel", "replacement": "abs", "replacementUpper": "ABS", "category": "brand", "defaultWave": "W0", "reviewOnly": true},
    {"legacy": "discreetgaming", "replacement": "abs", "replacementUpper": "ABS", "category": "brand", "defaultWave": "W0", "reviewOnly": true},
    {"legacy": "com.dgphoenix", "replacement": "com.abs", "replacementUpper": "com.abs", "category": "package", "defaultWave": "W3", "reviewOnly": true, "requiresWrapper": true},
    {"legacy": "dgphoenix", "replacement": "abs", "replacementUpper": "ABS", "category": "package", "defaultWave": "W3", "reviewOnly": true, "requiresWrapper": true},
    {"legacy": "mq", "replacement": "abs", "replacementUpper": "ABS", "category": "token", "defaultWave": "W0", "reviewOnly": true, "notes": ["High collision risk: only replace with explicit context filters."]}
  ],
  "protectedPatterns": [
    "docs/phase9/",
    "legacy inventory baseline evidence",
    "external sample payloads unless wave-specific override is approved"
  ]
}
