{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "slot-browser-v1/resumegame.request.schema.json",
  "title": "slot-browser-v1 resumegame request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "sessionId",
    "requestCounter",
    "idempotencyKey",
    "clientOperationId",
    "currentStateVersion",
    "bootstrapRef",
    "selectedBet",
    "selectedFeatureChoice",
    "resumeRef"
  ],
  "properties": {
    "contractVersion": {
      "type": "string",
      "const": "slot-browser-v1"
    },
    "sessionId": {
      "type": "string"
    },
    "requestCounter": {
      "type": "integer",
      "minimum": 0
    },
    "idempotencyKey": {
      "type": "string"
    },
    "clientOperationId": {
      "type": "string"
    },
    "currentStateVersion": {
      "type": "integer",
      "minimum": 0
    },
    "bootstrapRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "configId",
        "clientPackageVersion",
        "mathPackageVersion"
      ],
      "properties": {
        "configId": {
          "type": "string"
        },
        "clientPackageVersion": {
          "type": "string"
        },
        "mathPackageVersion": {
          "type": "string"
        }
      }
    },
    "selectedBet": {
      "type": "null"
    },
    "selectedFeatureChoice": {
      "type": "null"
    },
    "resumeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unfinishedRoundId",
        "resumeToken"
      ],
      "properties": {
        "unfinishedRoundId": {
          "type": "string"
        },
        "resumeToken": {
          "type": "string"
        }
      }
    }
  }
}
