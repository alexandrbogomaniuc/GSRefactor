    "@gamesv1/ui-kit": "workspace:*",
    "@esotericsoftware/spine-pixi-v8": "^4.2.74",
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "^2.3.2",
    "motion": "^12.4.7",
    "pixi.js": "^8.8.1"
  },
  "devDependencies": {
    "@assetpack/core": "^1.4.0",
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.5.3",
