{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gethistory.request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "sessionId", "requestCounter", "currentStateVersion", "historyQuery"],
  "properties": {
    "contractVersion": { "const": "slot-browser-v1" },
    "sessionId": { "type": "string", "minLength": 1 },
    "requestCounter": { "type": "integer", "minimum": 0 },
    "currentStateVersion": { "type": "integer", "minimum": 0 },
    "historyQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pageNumber", "pageSize"],
      "properties": {
        "pageNumber": { "type": "integer", "minimum": 0 },
        "pageSize": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
