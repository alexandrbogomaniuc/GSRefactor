{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@gamesv1/*": [
        "packages/*/src"
      ],
      "@pixi/layout": [
        "packages/pixi-layout/src"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "games",
    "tools",
    "tests",
    "docs"
  ]
}
