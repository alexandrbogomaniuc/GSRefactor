# Refactored release runtime template.
# Run ./prepare_runtime.sh after building web-gs to generate ./runtime/*,
# then copy this file to .env locally and adjust only the values you need.

TARGET_CASSANDRA_IMAGE=cassandra:5.0.6
LEGACY_CASSANDRA_IMAGE=cassandra:3.11
ZOOKEEPER_IMAGE=zookeeper:3.9
KAFKA_IMAGE=confluentinc/cp-kafka:7.6.1
WEBGS_IMAGE=tomcat:9-jdk11
STATIC_IMAGE=nginx:1.27-alpine

HEALTH_PORT=8080
STATIC_PORT=18080
TARGET_CASSANDRA_PORT=9143
LEGACY_CASSANDRA_PORT=9042
ZOOKEEPER_PORT=12181

# Prepared runtime inputs. Leave these defaults after running ./prepare_runtime.sh,
# or override them with absolute paths if you keep the bundles elsewhere.
WEBGS_WAR_PATH=./runtime/ROOT.patched.war
EXPORT_BUNDLE_PATH=./runtime/export_localmachine
STATIC_HTML5_PATH=./runtime/static_html5

# Optional: point this at a real html5pc bundle before running ./prepare_runtime.sh
# if you want the standalone static facade to serve the legacy client assets.
# STATIC_HTML5_SOURCE=/absolute/path/to/html5pc

# Runtime flags
CASSANDRA_HOSTS=fullstack-cassandra:9042
ZOOKEEPER_CONNECT=fullstack-zookeeper:2181
KAFKA_BOOTSTRAP=fullstack-kafka:9092
