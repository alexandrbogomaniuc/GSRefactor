# Refactored release runtime template
# Copy to .env locally and adjust paths for your machine or deployment workspace.

TARGET_CASSANDRA_IMAGE=cassandra:5.0.6
LEGACY_CASSANDRA_IMAGE=cassandra:3.11
ZOOKEEPER_IMAGE=zookeeper:3.9
KAFKA_IMAGE=confluentinc/cp-kafka:7.6.1
WEBGS_IMAGE=tomcat:9-jdk11
STATIC_IMAGE=nginx:1.27-alpine

HEALTH_PORT=8080
STATIC_PORT=18080
TARGET_CASSANDRA_PORT=9043
LEGACY_CASSANDRA_PORT=9042
ZOOKEEPER_PORT=2181

# Build artifact and runtime asset inputs
WEBGS_WAR_PATH=../../game-server/web-gs/target/ROOT.war
EXPORT_BUNDLE_PATH=/absolute/path/to/export_localmachine
STATIC_HTML5_PATH=/absolute/path/to/html5pc

# Runtime flags
CASSANDRA_HOSTS=fullstack-cassandra:9042
ZOOKEEPER_CONNECT=fullstack-zookeeper:2181
KAFKA_BOOTSTRAP=fullstack-kafka:9092
