<ClusterConfig>
    <clusterName>clusterName</clusterName>
    <validateClusterName>false</validateClusterName>
    <keySpace>ksName</keySpace>
    <hostTimeoutWindow>30000</hostTimeoutWindow>
    <replicationStrategyClass>org.apache.cassandra.locator.NetworkTopologyStrategy</replicationStrategyClass>
    <readConsistencyLevel>2</readConsistencyLevel>
    <writeConsistencyLevel>2</writeConsistencyLevel>
    <serialConsistencyLevel>LOCAL_SERIAL</serialConsistencyLevel>
    <createScheme>true</createScheme>
    <hosts>hostsblablalba</hosts>
    <minimumOnlineHosts>3</minimumOnlineHosts>
    <localDataCenterName>dc02</localDataCenterName>
    <connectTimeoutMillis>12000</connectTimeoutMillis>
    <readTimeoutMillis>65000</readTimeoutMillis>
    <tcpNoDelay>false</tcpNoDelay>
    <reuseAddress>false</reuseAddress>
    <keepAlive>false</keepAlive>
    <maxConnectionsPerHost>3</maxConnectionsPerHost>
    <coreConnectionsPerHost>2</coreConnectionsPerHost>
    <heartbeatIntervalSeconds>95</heartbeatIntervalSeconds>
    <maxRequestsPerConnection>4096</maxRequestsPerConnection>
    <enableDcAwareLoadBalancing>true</enableDcAwareLoadBalancing>
    <dcReplicationFactors>dc01:1,dc02:3</dcReplicationFactors>
    <columnFamilies>
        <ColumnFamily>
            <className>com.dgphoenix.casino.alert.AlertPersister</className>
            <!-- 1 week -->
            <ttl>604800</ttl>
            <enabled>true</enabled>
        </ColumnFamily>
        <ColumnFamily>
            <className>com.dgphoenix.casino.alert.BucketPersister</className>
            <!-- 1 week -->
            <ttl>604800</ttl>
            <enabled>true</enabled>
        </ColumnFamily>
    </columnFamilies>
</ClusterConfig>
