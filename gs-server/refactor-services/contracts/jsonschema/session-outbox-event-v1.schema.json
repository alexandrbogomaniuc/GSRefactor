{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://abs.dev/contracts/session-outbox-event-v1.schema.json",
  "title": "ABS Session Outbox Event v1",
  "type": "object",
  "required": ["eventId", "eventType", "createdAt", "payload"],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "enum": ["session.created", "session.touched", "session.closed"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "required": ["bankId", "sessionId"],
      "properties": {
        "bankId": { "type": "string", "minLength": 1 },
        "sessionId": { "type": "string", "minLength": 1 },
        "userId": { "type": "string" },
        "gameId": { "type": "string" },
        "lastTouchedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
